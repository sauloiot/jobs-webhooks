# Template do .env do jobs-webhooks. Copie para `.env` e preencha os valores.
#   cp .env.example .env

PORT=8083
LOG_LEVEL=info

# Token cadastrado no painel do Asaas (Integrações -> Webhooks).
# MESMO valor usado pelo jobs-api (asaas.webhook.token) — rotação toca os 3 lugares.
ASAAS_WEBHOOK_TOKEN=

# Fila SQS FIFO de billing (irmã da joblly-realtime-events-dev.fifo)
ASAAS_BILLING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/713881829449/joblly-billing-webhooks-dev.fifo
SQS_REGION=us-east-1
SQS_ENDPOINT_OVERRIDE=

# Reaproveite as mesmas credenciais usadas no jobs-api (S3 + SQS, mesmo IAM user).
# Veja `aws.s3.access-key` / `aws.s3.secret-key` em jobs-api/src/main/resources/application-dev.properties
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
